# pixi environments
.pixi/*
!.pixi/config.toml

# Python caches
__pycache__/
*.py[cod]
*$py.class

# Local secrets
.env
/NIFS_API_KEY

# Generated data and analysis products
data/**
!data/
!data/README.md
!data/raw/
!data/raw/.gitkeep
!data/interim/
!data/interim/.gitkeep
outputs/**
!outputs/
!outputs/README.md
!outputs/tables/
!outputs/tables/.gitkeep
!outputs/figures/
!outputs/figures/.gitkeep

# Notebook/editor artifacts
.ipynb_checkpoints/
.vscode/
**/.ipynb_checkpoints/

# Legacy/generated root-level downloads
/kodc*.json
/kodc*.csv
